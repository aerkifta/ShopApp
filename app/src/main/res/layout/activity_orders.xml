<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#F5F5F5">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Заказы клиента"
        android:textSize="24sp"
        android:textStyle="bold"
        android:paddingBottom="16dp"
        android:textColor="#222222"/>

    <EditText
        android:id="@+id/etClientFullName"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="ФИО клиента"
        android:inputType="text"
        android:textColor="#000000"
        android:textColorHint="#808080"/>

    <EditText
        android:id="@+id/etDateFrom"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="Дата от (2026-05-01)"
        android:padding="12dp"
        android:background="@android:drawable/edit_text"
        android:layout_marginBottom="12dp"
        android:textColor="#000000"
        android:textColorHint="#808080"/>

    <EditText
        android:id="@+id/etDateTo"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="Дата до (2026-05-30)"
        android:padding="12dp"
        android:background="@android:drawable/edit_text"
        android:layout_marginBottom="16dp"
        android:textColor="#000000"
        android:textColorHint="#808080"/>

    <Button
        android:id="@+id/btnShow"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Показать"
        android:textAllCaps="false"
        android:backgroundTint="#1976D2"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Результаты"
        android:textStyle="bold"
        android:textSize="18sp"
        android:paddingBottom="8dp"
        android:textColor="#333333"/>

    <ListView
        android:id="@+id/listViewOrders"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:dividerHeight="8dp"
        android:background="#FFFFFF"/>

</LinearLayout>